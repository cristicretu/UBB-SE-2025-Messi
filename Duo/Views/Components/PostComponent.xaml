<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Duo.Views.Components.PostComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Duo.Views.Components"
    xmlns:components="using:Duo.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="800"
    HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- Styles for the post component -->
        <Style x:Key="PostBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Transitions">
                <Setter.Value>
                    <TransitionCollection>
                        <ContentThemeTransition />
                    </TransitionCollection>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="PostBorder" Style="{StaticResource PostBorderStyle}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="HoverStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                        <Setter Target="PostBorder.Background" Value="White" />
                        <Setter Target="PostBorder.BorderBrush" Value="#EEEEEE" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        
        <StackPanel Padding="16,12,16,12" Spacing="20">
            <!-- Header Section -->
            <StackPanel Spacing="10">
                <!-- Username and Date Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="{x:Bind Username, Mode=OneWay}" 
                              Grid.Column="0"
                              FontWeight="SemiBold" 
                              FontSize="12"
                              Opacity="0.6"/>
                    
                    <TextBlock Text="{x:Bind Date, Mode=OneWay}" 
                              Grid.Column="1"
                              FontWeight="SemiBold"
                              FontSize="10"
                              Opacity="0.4"/>
                </Grid>

                <!-- Post Title -->
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" 
                          FontWeight="Bold"
                          FontSize="14"
                          TextWrapping="Wrap"/>

                <!-- Tags/Chips -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#F0F0F0" 
                           CornerRadius="10" 
                           Padding="12,4,12,4">
                        <TextBlock Text="#apple" 
                                  FontSize="12"
                                  Foreground="Black"/>
                    </Border>
                    
                    <Border Background="#F0F0F0" 
                           CornerRadius="10" 
                           Padding="12,4,12,4">
                        <TextBlock Text="#MacBook" 
                                  FontSize="12"
                                  Foreground="Black"/>
                    </Border>
                    
                    <Border Background="#F0F0F0" 
                           CornerRadius="10" 
                           Padding="12,4,12,4">
                        <TextBlock Text="#M1Max" 
                                  FontSize="12"
                                  Foreground="Black"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Post Content -->
            <TextBlock TextWrapping="Wrap"
                      FontSize="12"
                      Text="{x:Bind ContentText, Mode=OneWay}"/>

            <!-- Likes Row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="LikeButton" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             Padding="0"
                             Click="LikeButton_Click"
                             IsChecked="{x:Bind IsLiked, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon x:Name="HeartIcon" 
                                 Glyph="&#xE00B;" 
                                 FontSize="16"
                                 Foreground="{x:Bind HeartColor, Mode=OneWay}"/>
                    </StackPanel>
                </ToggleButton>
                <TextBlock x:Name="LikesCountText" 
                          Text="{x:Bind LikesText, Mode=OneWay}" 
                          VerticalAlignment="Center"
                          FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl> 