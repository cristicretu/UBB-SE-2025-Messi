<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Duo.Views.Pages.PostListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Duo.Views.Pages"
    xmlns:components="using:Duo.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Center content with max width -->
        <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollMode="Auto">
            <Grid HorizontalAlignment="Center" MaxWidth="900">
                <!-- Main content column -->
                <StackPanel Spacing="16" Padding="16,48,16,48">
                    
                    <!-- Title row with search -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title -->
                        <TextBlock Text="{x:Bind CategoryName, Mode=OneWay}" 
                                Grid.Column="0"
                                FontSize="28" 
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"/>
                        
                        <!-- Search box -->
                        <AutoSuggestBox x:Name="SearchBox" 
                                Grid.Column="1"
                                Width="240"
                                PlaceholderText="Search posts"
                                QueryIcon="Find"
                                TextChanged="SearchBox_TextChanged"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </Grid>
                    
                    <!-- Divider -->
                    <Rectangle Height="1" Fill="Black" Opacity="0.1" Stretch="Fill"/>
                    
                    <!-- Filter chips row with horizontal scrolling and drag capability -->
                    <ScrollViewer x:Name="FilterScrollViewer" 
                                  HorizontalScrollMode="Enabled" 
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,0">
                        <ItemsRepeater x:Name="FilterChips" ItemsSource="{x:Bind TagFilters}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <RadioButton 
                                        Content="{x:Bind}"
                                        GroupName="TagFilters"
                                        Checked="FilterChip_Checked"
                                        IsThreeState="False"
                                        Style="{StaticResource SegmentedItemRadioButtonStyle}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                    
                    <!-- Post List -->
                    <StackPanel x:Name="PostList" Spacing="8">
                        <!-- Sample posts - will be populated dynamically -->
                        <components:PostComponent />
                        <Rectangle Height="1" Fill="Black" Opacity="0.1" Stretch="Fill"/>
                        
                        <components:PostComponent />
                        <Rectangle Height="1" Fill="Black" Opacity="0.1" Stretch="Fill"/>
                        
                        <components:PostComponent />
                        <Rectangle Height="1" Fill="Black" Opacity="0.1" Stretch="Fill"/>
                    </StackPanel>
                    
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
